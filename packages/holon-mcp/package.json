{
  "name": "holon-mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Holon CLI-only MCP stdio server.",
  "bin": {
    "holon-mcp": "./src/server.ts"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "scaffold-secretary": "tsx src/scaffold-secretary.ts",
