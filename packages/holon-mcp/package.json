    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@holon/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "20.16.5",
    "tsx": "4.19.1",
    "typescript": "5.5.4"
  }
}
