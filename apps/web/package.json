{
  "name": "@holon/web",
  "version": "0.0.0",
  "private": true,
  "description": "Holon desk app — Next.js 15 + React 19. Hosts the BFF (app/api/v1/*) and the React UI.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/sync-vanilla.mjs && next dev --port 3000",
    "build": "node scripts/sync-vanilla.mjs && next build",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "next lint",
    "sync:vanilla": "node scripts/sync-vanilla.mjs",
    "reset": "node scripts/reset.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.5",
    "@assistant-ui/styles": "0.3.7",
    "@auth/drizzle-adapter": "^1.11.2",
    "@holon/api-contract": "workspace:*",
    "@holon/auth": "workspace:*",
    "@holon/core": "workspace:*",
    "@next/env": "15.5.18",
    "better-sqlite3": "^12.10.0",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.45.2",
    "jsqr": "^1.4.0",
    "next": "15.5.18",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "20.16.5",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "autoprefixer": "10.4.20",
    "playwright": "^1.60.0",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.14",
    "typescript": "5.5.4",
    "vitest": "2.1.1"
  }
}
