# Copy this file to .env (which is gitignored) and fill in real values.
# Do NOT commit .env.

# DeepSeek API (chat / reasoning models)
# Get at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# (Future: add other API keys here as integrations land.)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# HERMES_API_BASE=http://localhost:8000

# iter-011 Pass #1 — Gmail OAuth + token encryption (per ADR-022)
# Get client_id / client_secret from https://console.cloud.google.com/apis/credentials
# Redirect URI to register: http://localhost:3000/api/v1/integrations/oauth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# generate via: openssl rand -base64 32
HOLON_TOKEN_ENC_KEY=

# iter-011 Pass #3 — shared secret guarding the BFF token-fetch / refresh
# routes called by the Hermes Gmail plugin sidecar. Same value must be
# exported into the Python sidecar's process env (the dispatcher inherits
# it from the BFF process).
# generate via: openssl rand -base64 32
HOLON_PLUGIN_SHARED_SECRET=

# Holon-internal config (later iterations may move these elsewhere)
# HOLON_DESK_ID=desk_local
# HOLON_PERSON_ID=person_local
# HOLON_RELAY_URL=https://relay.holon.dev

# Telegram ingress poller gate (L-102).
# Default (unset or any value other than 'false'): poller is ENABLED — main app works with no change.
# Set to 'false' in secondary worktrees (e.g. mobile dev :3002) to suppress getUpdates and avoid
# the Bot API 409 conflict storm when two instances share the same bot token.
# TELEGRAM_INGRESS_ENABLED=false

# Feedback → GitHub issue (TRUSTED-TESTER ONLY — move to server-side Worker before public launch)
# When set, each bug report also opens a GitHub issue in HOLON_FEEDBACK_GITHUB_REPO.
# Token must be a fine-grained PAT scoped to Issues:read+write on chenz16/holon-engineering only.
# Leave blank (or omit) for local-only mode (default / safe for untrusted users).
# See TECH-DEBT.md entry "D-github-feedback" for the Worker migration task.
# HOLON_FEEDBACK_GITHUB_TOKEN=github_pat_...
# HOLON_FEEDBACK_GITHUB_REPO=chenz16/holon-engineering
