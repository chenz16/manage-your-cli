# scripts/.env.test.local -- test-profile build secrets
#
# Copy this file to scripts/.env.test.local and fill in real values.
# The real .env.test.local is GITIGNORED; never commit it.
#
# Used by: build-windows-installer-local.ps1 -Profile test
# Effect:  these values are baked into the Next.js standalone server bundle
#          at build time via apps/web/.env.production.local (written + deleted
#          by the PS1 script; not left on disk after the build).
#
# How each key is consumed at runtime:
#   DEEPSEEK_API_KEY         -- llm-provider-resolver.ts fallback chain (b):
#                               if no owner LLM provider is configured in the
#                               UI, the resolver falls back to this env var to
#                               bootstrap DeepSeek calls.
#   HOLON_FEEDBACK_GITHUB_TOKEN -- app/api/v1/admin/bugs/route.ts:
#                               when set, bug reports filed via the Holon UI
#                               also open GitHub issues on HOLON_FEEDBACK_GITHUB_REPO.
#                               Requires a GitHub PAT with `repo` scope on the
#                               target repo. Non-fatal if absent -- bug reports
#                               still save to disk.
#   HOLON_FEEDBACK_GITHUB_REPO  -- target repo for GitHub issue creation.
#                               Default (if absent): chenz16/holon-engineering.
#                               For test builds pointing at a private feedback
#                               repo, set this explicitly.

DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
HOLON_FEEDBACK_GITHUB_TOKEN=ghp_your-github-pat-here
HOLON_FEEDBACK_GITHUB_REPO=chenz16/holon-engineering
